{
  "name": "journey-planner-root",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start": "concurrently \"yarn dev:backend\" \"yarn dev:frontend\"",
    "dev:backend": "yarn workspace backend dev",
    "dev:frontend": "yarn workspace frontend dev",
    "build:backend": "yarn workspace backend build",
    "build:frontend": "yarn workspace frontend build",
    "generate": "concurrently \"yarn workspace backend generate\" \"yarn workspace frontend generate\""
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1"
  }
}
